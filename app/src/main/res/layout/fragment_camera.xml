<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <!-- Camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fullscreen toggle -->
    <ImageButton
        android:id="@+id/btnFullscreen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/icon_button_bg"
        android:contentDescription="@string/toggle_fullscreen"
        android:src="@drawable/ic_fullscreen"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zone label overlay -->
    <TextView
        android:id="@+id/zoneLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/zone_label_bg"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="4dp"
        android:text="@string/detecting"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

    <!-- Fullscreen toggle -->

    <!--header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App icon -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_app_icon"
            android:background="@drawable/icon_teal_bg"
            android:padding="6dp"
            android:contentDescription="@string/app_icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <!-- Active pill -->
        <TextView
            android:id="@+id/activePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_active"
            android:textColor="#5DCAA5"
            android:textSize="11sp"
            android:background="@drawable/pill_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

    </LinearLayout>

    <!-- bottom panel -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bottom_panel_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mode toggle -->
        <LinearLayout
            android:id="@+id/modeToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:background="@drawable/toggle_bg"
            android:padding="4dp">

            <Button
                android:id="@+id/btnAutomatic"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/mode_automatic"
                android:textSize="13sp"
                android:background="@drawable/toggle_selected_bg"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnManual"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/mode_manual"
                android:textSize="13sp"
                android:background="@null"
                android:textColor="#66FFFFFF" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot_active" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_fps"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/objectCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/objects_count"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:gravity="center"
            android:weightSum="3">

            <LinearLayout
                android:id="@+id/btnSpeak"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/action_button_bg"
                android:layout_marginEnd="4dp"
                android:alpha="0.4">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_volume"
                    android:contentDescription="@string/action_speak" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_speak"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPause"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/action_button_bg"
                android:layout_marginHorizontal="4dp">

                <ImageView
                    android:id="@+id/pauseIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_pause"
                    android:contentDescription="@string/action_pause" />

                <TextView
                    android:id="@+id/pauseLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_pause"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/action_button_bg"
                android:layout_marginStart="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="@string/action_settings" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_settings"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>